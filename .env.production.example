# =============================================================================
# Aexion Core - Production Environment Variables
# =============================================================================
# Copy this file to .env.production.local and fill in your values

# Database - PostgreSQL (production)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://aexion_user:your_secure_password@localhost:5432/aexion_core?schema=public"

# NextAuth - MUST change secret in production
NEXTAUTH_SECRET="generate-a-secure-random-string-at-least-32-chars"
NEXTAUTH_URL="https://your-domain.com"

# API Configuration
API_BASE_URL="https://your-domain.com"
NODE_ENV="production"

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID=""

# Optional: Email (for integrations)
# GMAIL_CLIENT_ID=""
# GMAIL_CLIENT_SECRET=""
# OUTLOOK_CLIENT_ID=""
# OUTLOOK_CLIENT_SECRET=""

# Optional: WhatsApp Business API
# WHATSAPP_API_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_VERIFY_TOKEN=""
