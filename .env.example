# ============================================
# Aexion Core — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# Database
# SQLite (development):
# DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL (production):
DATABASE_URL="postgresql://user:password@localhost:5432/aexion_dev"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters-please"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
GOOGLE_ID=""
GOOGLE_SECRET=""
MICROSOFT_ID=""
MICROSOFT_SECRET=""

# Integration OAuth Credentials
# Gmail integration (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Outlook / Microsoft 365 integration (Azure Portal → App Registrations)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# API Configuration
API_BASE_URL="http://localhost:3000"
NODE_ENV="development"
